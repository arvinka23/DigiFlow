@using DigitalisierungsManager.Services.Health

@if (Assessment != null)
{
    var color = Assessment.Level switch
    {
        HealthLevel.Gesund => "#22c55e",
        HealthLevel.Beobachten => "#eab308",
        HealthLevel.Handlungsbedarf => "#f97316",
        _ => "#ef4444"
    };
    var circumference = 2 * Math.PI * 18;
    var dash = circumference * Assessment.Score / 100.0;

    <div class="health-ring" title="@LevelLabel" style="width:@(Size)px; height:@(Size)px;">
        <svg viewBox="0 0 44 44" width="@Size" height="@Size">
            <circle cx="22" cy="22" r="18" fill="none" stroke="var(--border-color)" stroke-width="4" />
            <circle cx="22" cy="22" r="18" fill="none" stroke="@color" stroke-width="4"
                    stroke-dasharray="@($"{dash.ToString(System.Globalization.CultureInfo.InvariantCulture)} {circumference.ToString(System.Globalization.CultureInfo.InvariantCulture)}")"
                    stroke-linecap="round" transform="rotate(-90 22 22)" />
            <text x="22" y="26" text-anchor="middle" fill="var(--text-primary)"
                  style="font-size:13px; font-weight:600; font-family:Inter, sans-serif">
                @Assessment.Score
            </text>
        </svg>
    </div>
}

@code {
    [Parameter] public HealthAssessment? Assessment { get; set; }
    [Parameter] public int Size { get; set; } = 44;

    private string LevelLabel => Assessment == null ? "" : $"Gesundheit: {Assessment.Level} ({Assessment.Score}/100)";
}
